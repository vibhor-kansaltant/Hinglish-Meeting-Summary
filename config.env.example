# Zoom & Teams Transcriber - Configuration
# ─────────────────────────────────────────
# Copy this file to config.env and fill in your Anthropic API key.
# Get your key from: https://console.anthropic.com
#
# The summary is generated after each meeting and appended to the transcript.
# It includes: Summary, Key Topics, Action Items, Decisions, Questions, Takeaways.
#
# Leave blank to disable summaries (transcription still works fine without it).

ANTHROPIC_API_KEY=
